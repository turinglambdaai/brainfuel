<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:BrainFuel.Controls"
        xmlns:vm="clr-namespace:BrainFuel.ViewModels"
        x:Class="BrainFuel.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="BrainFuel"
        Width="380" Height="200"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        Topmost="True"
        Background="#1F1F1E"
        WindowStartupLocation="Manual">

    <Window.Styles>
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1AF0EEE6"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button.ghost:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#33F0EEE6"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </Window.Styles>

    <Border x:Name="CardBorder"
            Padding="20"
            Background="#1F1F1E"
            BorderBrush="#26F0EEE6"
            BorderThickness="1"
            PointerPressed="Card_PointerPressed">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="立即刷新" Click="Refresh_Click"/>
                <MenuItem Header="设置…" Click="Settings_Click"/>
                <Separator/>
                <MenuItem Header="退出" Click="Quit_Click"/>
            </ContextMenu>
        </Border.ContextMenu>

        <Grid ColumnDefinitions="148, *">
            <ctl:UsageRing Grid.Column="0"
                           Width="142" Height="142"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           WeeklyProgress="{Binding WeeklyProgress}"
                           HourlyProgress="{Binding HourlyProgress}"/>

            <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Center">
                <!-- refresh button (displays last refresh, click to refresh) -->
                <Button Classes="ghost" HorizontalAlignment="Right" Click="Refresh_Click">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="↻" FontSize="13" Foreground="#FF9B968B"/>
                        <TextBlock Text="{Binding RefreshAgoText}" FontSize="11" Foreground="#FF9B968B"/>
                    </StackPanel>
                </Button>

                <!-- 5-hour window -->
                <StackPanel Spacing="3" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding HourlyPercentText}"
                               FontSize="23" FontWeight="Bold" Foreground="#FFF0EEE6"
                               HorizontalAlignment="Right"/>
                    <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
                        <Ellipse Width="6" Height="6" Fill="#FFE8D4B8" VerticalAlignment="Center"/>
                        <TextBlock Text="5 小时" FontSize="11" Foreground="#FFA39E94" VerticalAlignment="Center"/>
                        <PathIcon Width="11" Height="11" Margin="10,0,2,0" Foreground="#FF9B968B"
                                  Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                        <TextBlock Text="{Binding HourlySubText}" FontSize="11" Foreground="#FFB8B2A6" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <Border Height="1" Width="140" Background="#FF36352F" Margin="0,1" HorizontalAlignment="Right"/>

                <!-- weekly -->
                <StackPanel Spacing="3" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding WeeklyPercentText}"
                               FontSize="23" FontWeight="Bold" Foreground="#FFF0EEE6"
                               HorizontalAlignment="Right"/>
                    <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
                        <Ellipse Width="6" Height="6" Fill="#FFD97757" VerticalAlignment="Center"/>
                        <TextBlock Text="周用量" FontSize="11" Foreground="#FFA39E94" VerticalAlignment="Center"/>
                        <PathIcon Width="11" Height="11" Margin="10,0,2,0" Foreground="#FF9B968B"
                                  Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                        <TextBlock Text="{Binding WeeklySubText}" FontSize="11" Foreground="#FFB8B2A6" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
