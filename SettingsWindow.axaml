<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BrainFuel.ViewModels"
        x:Class="BrainFuel.SettingsWindow"
        Title="BrainFuel 设置"
        Width="440" Height="430"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="True"
        Topmost="True"
        WindowDecorations="Full">
    <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0" Margin="22,20,22,8" Spacing="10">
            <TextBlock Text="GLM 套餐额度监控" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="填入你的 GLM Coding Plan Key 与平台，控件会用它查询额度。" Foreground="#FF9FA0A0" TextWrapping="Wrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="22,0">
            <StackPanel Spacing="14">
                <StackPanel Spacing="4">
                    <TextBlock Text="API Key"/>
                    <TextBox x:Name="KeyBox" PlaceholderText="粘贴 GLM Coding Plan Key" PasswordChar="•" Width="380"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="平台"/>
                    <ComboBox x:Name="PlatformBox" SelectedIndex="0" Width="380">
                        <ComboBoxItem Content="智谱国内 · open.bigmodel.cn"/>
                        <ComboBoxItem Content="Z.ai 国际 · api.z.ai"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="刷新间隔（分钟）"/>
                    <NumericUpDown x:Name="IntervalBox" Minimum="1" Maximum="60" Value="5" Width="160"/>
                </StackPanel>

                <StackPanel Spacing="6">
                    <CheckBox x:Name="WeeklyRemaining" Content="周用量显示「剩余」而非「已用」"/>
                    <CheckBox x:Name="HourlyRemaining" Content="5 小时显示「剩余」而非「已用」"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="22,8,22,18">
            <Button Content="取消" Click="Cancel_Click" Width="88"/>
            <Button Content="保存" Click="Save_Click" Width="88" Classes="accent"/>
        </StackPanel>
    </Grid>
</Window>
